# --- LeoNes API server (website/server) ---
# Port for the API server (Vite proxies /api here)
PORT=4242
# Public URL of the storefront (used in Stripe redirect URLs)
APP_URL=http://localhost:5173
# Comma-separated admin emails allowed to view /admin/orders
ADMIN_EMAILS=jorge.manuel.granja@gmail.com

# --- Stripe (test mode) ---
# From https://dashboard.stripe.com/test/apikeys - starts with sk_test_
# Leave unset to use the built-in local DEV payment simulator.
STRIPE_SECRET_KEY=
# From `stripe listen` or the dashboard webhook config - starts with whsec_
STRIPE_WEBHOOK_SECRET=

# --- Shipping ---
SHIPPING_FLAT=4.90
FREE_SHIPPING_OVER=35
